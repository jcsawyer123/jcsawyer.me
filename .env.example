# Feature Flags
# All flags default to false. Set to true to enable.
# Accepted values: true/false, 1/0, yes/no, on/off

# Pages
FLAG_SHOW_BLOG_PAGE=false
FLAG_SHOW_CONTACT_PAGE=false
FLAG_SHOW_SELECTED_WORK_PAGE=false

# Homepage sections
FLAG_SHOW_HOMEPAGE_EXPERIENCE=false
FLAG_SHOW_HOMEPAGE_EXPERIENCE_BULLETS=false
FLAG_SHOW_HOMEPAGE_SKILLS=false
FLAG_SHOW_HOMEPAGE_SELECTED_WORK=false
FLAG_SHOW_HOMEPAGE_WRITING=false      # also requires FLAG_SHOW_BLOG_PAGE=true

# Content
FLAG_SHOW_DRAFTS=false                # show posts with draft: true in frontmatter

# Blog
FLAG_USE_COMPACT_BLOG_ARCHIVE=false   # false = full cards, true = date/title rows

# UI
FLAG_ENABLE_HEADING_ANCHORS=false

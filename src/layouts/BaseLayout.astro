---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ThemeScript from '../components/ThemeScript.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css'; // Import CSS in the frontmatter

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = 'My personal website'
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset="UTF-8" />
    <SEO title={title} description={description} />

    {/* Theme handling scripts */}
    <ThemeScript />
  </head>
  
  <body class="relative overflow-x-hidden min-h-screen text-content">
    {/* Grid Pattern - Fixed Position */}
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 z-0">
      <svg class="w-full h-full opacity-[0.35] dark:opacity-[0.15] text-border dark:text-border" width="100%" height="100%">
        <defs>
          <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="1" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    {/* Main Content Wrapper */}
    <div class="relative z-20">
      <Navbar currentPath={currentPath} />
      
      <main class="mt-24 flex-grow ">
        <slot />
      </main>
      
      <Footer />
    </div>
  </body>
</html>
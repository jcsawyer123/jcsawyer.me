---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SocialIcon from '../components/SocialIcon.astro';
import ProjectCard from '../components/sections/ProjectCard.astro';
import BlogPreviewCard from '../components/sections/BlogPreviewCard.astro';
import { getCollection } from 'astro:content';
import ExperienceSection from '../components/sections/ExperienceSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';

const projectEntries = await getCollection('projects');
const featuredProjects = projectEntries.filter(p => p.data.featured).slice(0, 2);
const otherProjects = projectEntries.filter(p => !p.data.featured).slice(0, 4);
const projectsToShow = [...featuredProjects, ...otherProjects].slice(0, 6);
const blogPosts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 4);
---

<BaseLayout title="Joshua Sawyer - Software Engineer">

  {/* --- Hero --- */}
  <section id="home" class="w-full mb-4">
    <div class="max-w-4xl mx-auto px-4 w-full">
      <div class="max-w-3xl py-12 sm:py-20">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-content-strong tracking-tight leading-[1.05] mb-5">
          Joshua<br />Sawyer
        </h1>
        <p class="text-sm sm:text-base font-semibold uppercase tracking-[0.22em] text-theme-700 dark:text-theme-400 mb-6">
          Software Engineer
        </p>
        <p class="text-content max-w-2xl text-base sm:text-lg leading-8 mb-10">
          Software engineer at LevelBlue, where I work on distributed backend systems primarily in Erlang — building analytics pipeline services, owning AWS integrations, and modernising internal Erlang tooling. I have full-stack range across JavaScript, TypeScript, and various frameworks. Outside of work, I'm a trustee at Hackathons UK, a charity I helped build to support student hackathons and tech societies across the UK.
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <Button href="/blog" variant="primary">Blog</Button>
          <Button href="/contact" variant="outline">Contact</Button>
          <div class="flex gap-3 pl-4 border-l border-border ml-1">
            <SocialIcon label="GitHub" href="https://github.com/jcsawyer123" aria-label="GitHub" />
            <SocialIcon label="LinkedIn" href="https://www.linkedin.com/in/joshua-sawyer/" aria-label="LinkedIn" />
            <SocialIcon label="Twitter" href="https://twitter.com/jcsawyer123" aria-label="Twitter" />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* --- Experience --- */}
  <ExperienceSection />

  {/* --- Skills --- */}
  <SkillsSection />

  {/* --- Selected Work --- */}
  <section id="projects" class="w-full mb-16">
    <div class="max-w-4xl mx-auto px-4 w-full">
      <div class="max-w-3xl mx-auto pt-12">
        <div class="flex items-center gap-4 mb-10">
          <span class="text-xs font-mono text-theme-500 dark:text-theme-400 tracking-widest shrink-0">03</span>
          <h2 class="text-2xl font-bold text-content-strong shrink-0">Selected Work</h2>
          <div class="flex-1 h-px bg-border-subtle"></div>
          {projectEntries.length > projectsToShow.length && (
            <a href="/projects" class="text-sm text-content-muted hover:text-content transition-colors shrink-0">View all →</a>
          )}
        </div>
        <p class="text-sm sm:text-base text-content-muted max-w-2xl leading-7 mb-8">
          A mix of professional work, community building, and the occasional personal build when it meaningfully reflects how I like to engineer systems.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {projectsToShow.map(project => (
            <div>
              <ProjectCard class="transition-all duration-200 hover:-translate-y-1" project={project.data} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* --- Writing --- */}
  <section id="blog" class="w-full mb-20">
    <div class="max-w-4xl mx-auto px-4 w-full">
      <div class="max-w-3xl mx-auto pt-12">
        <div class="flex items-center gap-4 mb-10">
          <span class="text-xs font-mono text-theme-500 dark:text-theme-400 tracking-widest shrink-0">04</span>
          <h2 class="text-2xl font-bold text-content-strong shrink-0">Writing</h2>
          <div class="flex-1 h-px bg-border-subtle"></div>
          <a href="/blog" class="text-sm text-content-muted hover:text-content transition-colors shrink-0">View all →</a>
        </div>
        <div class="space-y-4">
          {blogPosts.map(post => (
            <div class="transition-all duration-200 hover:-translate-y-1">
              <BlogPreviewCard post={post} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import SocialIcon from '../components/SocialIcon.astro';
import ProjectCard from '../components/sections/ProjectCard.astro';
import BlogPreviewCard from '../components/sections/BlogPreviewCard.astro';
import { getCollection } from 'astro:content';
import GradientAccent from '../components/GradientAccent.astro';
import SectionHeader from '../components/sections/SectionHeader.astro';

const projectEntries = await getCollection('projects');
const featuredProjects = projectEntries.filter(p => p.data.featured).slice(0, 2);
const otherProjects = projectEntries.filter(p => !p.data.featured).slice(0, 4);
const projectsToShow = [...featuredProjects, ...otherProjects].slice(0, 6);
const blogPosts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 4);
---

<BaseLayout title="Joshua Sawyer - Software Engineer">
  {/* --- Hero Section --- */}
  <section id="home" class="w-full mb-16">
    <div class="content-container space-y-4">
      <Container
        frosted
        panel
        borderColor="border-slate-300 dark:border-slate-700"
        class="relative overflow-hidden p-6"
      >
        {/* Accent Gradient Line */}
        <GradientAccent position="left" size="lg" />
        <div class="py-4 px-4 sm:px-8">
          <div class="mb-6 flex flex-col sm:flex-row items-baseline">
            <h1 class="heading-1 text-slate-800 dark:text-slate-100">
              Joshua Sawyer
            </h1>
            <div class="hidden md:flex px-3 text-slate-400 dark:text-slate-500 text-lg">/</div>
            <div class="body-text text-lg italic mt-2 sm:mt-0 sm:ml-4">
              Software Engineer
            </div>
          </div>
          <div class="border-t-2 border-slate-200 dark:border-slate-700 my-6 max-w-md"></div>
          <p class="body-text mb-8 max-w-xl">
            Passionate about engineering elegant and efficient solutions across the stack. Exploring the frontiers of backend systems and large-scale microarchitectures, with a love for hackathons and creative problem-solving.
          </p>
          <div class="flex flex-wrap gap-4">
            <Button href="#projects" variant="primary" class="focus-ring">View Portfolio</Button>
            <Button href="#contact" variant="outline" class="focus-ring">Contact Me</Button>
          </div>
          {/* Social Icons: static on mobile, absolute on desktop */}
          <div class="flex md:hidden justify-end pt-8">
            <Container
              borderColor="border-slate-700 dark:border-slate-600"
              class="px-1 py-1 mt-4"
            >
              <div class="flex gap-3">
                <SocialIcon label="GitHub" href="https://github.com" aria-label="GitHub" />
                <SocialIcon label="LinkedIn" href="https://linkedin.com" aria-label="LinkedIn" />
                <SocialIcon label="Twitter" href="https://twitter.com" aria-label="Twitter" />
              </div>
            </Container>
          </div>
        </div>
        {/* Social Icons: absolute in bottom right on desktop */}
        <div class="hidden md:flex absolute bottom-2 right-2">
          <Container borderColor="border-slate-700 dark:border-slate-600" class="px-1 py-1">
            <div class="flex gap-3">
              <SocialIcon label="GitHub" href="https://github.com" aria-label="GitHub" />
              <SocialIcon label="LinkedIn" href="https://linkedin.com" aria-label="LinkedIn" />
              <SocialIcon label="Twitter" href="https://twitter.com" aria-label="Twitter" />
            </div>
          </Container>
        </div>
      </Container>
    </div>
  </section>

  {/* --- Projects Section --- */}
  <section id="projects" class="w-full mb-16">
    <div class="content-container">
      <SectionHeader 
        title="Projects & Repositories"
        description="A selection of my recent work."
        accent="top"
        accentSize="md">
      </SectionHeader>

      {/* Project Grid */}
      <div class="max-w-3xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-6">
        {projectsToShow.map(project => (
        <div class="hover-lift">
          <ProjectCard project={project.data} />
        </div>
        ))}
      </div>

      {/* "View More" Button */}
      {projectEntries.length > projectsToShow.length && (
        <div class="mt-8 text-center">
          <Button href="/projects" variant="primary" class="focus-ring">View More Projects</Button>
        </div>
      )}
    </div>
  </section>


  {/* --- Blog Section --- */}
  <section id="blog" class="w-full mb-16">
    <div class="content-container">
      <SectionHeader 
        title="From the Blog"
        description="Recent articles and insights."
        actionButton={{
          text: 'View All',
          href: '/blog',
          variant: 'outline',
        }}
        accent="top"
        accentSize="md">
      </SectionHeader>

      <div class="max-w-3xl mx-auto space-y-4">
        {blogPosts.map(post => (
        <div class="hover-lift">
          <BlogPreviewCard post={post} />
        </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
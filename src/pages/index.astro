---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import SocialIcon from '../components/SocialIcon.astro';
import ProjectCard from '../components/sections/ProjectCard.astro';
import BlogPreviewCard from '../components/sections/BlogPreviewCard.astro';
import { getCollection } from 'astro:content';
import GradientAccent from '../components/GradientAccent.astro';
import SectionHeader from '../components/sections/SectionHeader.astro';
import ExperienceSection from '../components/sections/ExperienceSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';

const projectEntries = await getCollection('projects');
const featuredProjects = projectEntries.filter(p => p.data.featured).slice(0, 2);
const otherProjects = projectEntries.filter(p => !p.data.featured).slice(0, 4);
const projectsToShow = [...featuredProjects, ...otherProjects].slice(0, 6);
const blogPosts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 4);
---

<BaseLayout title="Joshua Sawyer - Software Engineer">
  {/* --- Hero Section --- */}
  <section id="home" class="w-full mb-16">
    <div class="max-w-4xl mx-auto px-4 w-full space-y-4">
      <Container
        frosted
        panel
        borderColor="border-border"
        class="relative overflow-hidden p-6"
      >
        {/* Accent Gradient Line */}
        <GradientAccent position="left" size="lg" />
        <div class="py-4 px-4 sm:px-8">
          <div class="mb-6 flex flex-col sm:flex-row items-baseline">
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-content-strong">
              Joshua Sawyer
            </h1>
            <div class="hidden md:flex px-3 text-content-subtle text-lg">/</div>
            <div class="text-content text-lg italic mt-2 sm:mt-0 sm:ml-4">
              Software Engineer
            </div>
          </div>
          <div class="border-t-2 border-border-subtle dark:border-border my-6 max-w-md"></div>
          <p class="text-content mb-8 max-w-xl">
            Software engineer at Fortra, where I work on distributed deployment systems primarily in Erlang — building backend services, owning AWS integrations, and modernising internal Erlang tooling. I have full-stack range across JavaScript, TypeScript, and various frameworks. Outside of work, I'm a trustee at Hackathons UK, a charity I helped build to support student hackathons and tech societies across the UK.
          </p>
          <div class="flex flex-wrap gap-4">
            <Button href="blog" variant="primary" class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-theme-400 dark:focus-visible:ring-accent-400">Blogs</Button>
            <Button href="contact" variant="outline" class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-theme-400 dark:focus-visible:ring-accent-400">Contact Me</Button>
          </div>
          {/* Social Icons: static on mobile, absolute on desktop */}
          <div class="flex md:hidden justify-end pt-8">
            <Container
              borderColor="border-border-emphasis"
              class="px-1 py-1 mt-4"
            >
              <div class="flex gap-3">
                <SocialIcon label="GitHub" href="https://github.com/jcsawyer123" aria-label="GitHub" />
                <SocialIcon label="LinkedIn" href="https://www.linkedin.com/in/joshua-sawyer/" aria-label="LinkedIn" />
                <SocialIcon label="Twitter" href="https://twitter.com/jcsawyer123" aria-label="Twitter" />
              </div>
            </Container>
          </div>
        </div>
        {/* Social Icons: absolute in bottom right on desktop */}
        <div class="hidden md:flex absolute bottom-2 right-2">
          <Container borderColor="border-border-emphasis" class="px-1 py-1">
            <div class="flex gap-3">
              <SocialIcon label="GitHub" href="https://github.com/jcsawyer123" aria-label="GitHub" />
              <SocialIcon label="LinkedIn" href="https://www.linkedin.com/in/joshua-sawyer/" aria-label="LinkedIn" />
              <SocialIcon label="Twitter" href="https://twitter.com/jcsawyer123" aria-label="Twitter" />
            </div>
          </Container>
        </div>
      </Container>
    </div>
  </section>

  {/* --- Experience Section --- */}
  <ExperienceSection />

  {/* --- Skills Section --- */}
  <SkillsSection />

  {/* --- Projects Section --- */}
  <section id="projects" class="w-full mb-16">
    <div class="max-w-4xl mx-auto px-4 w-full">
      <SectionHeader 
        title="Featured Work & Contributions"
        description="A glimpse into some of my recent coding endeavors, personal endeavours and random projects"
        accent="top"
        accentSize="md">
      </SectionHeader>

      {/* Project Grid */}
      <div class="max-w-3xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-6">
        {projectsToShow.map(project => (
        <div>
          <ProjectCard class="transition-all duration-200 hover:-translate-y-1" project={project.data} />
        </div>
        ))}
      </div>

      {/* "View More" Button */}
      {projectEntries.length > projectsToShow.length && (
        <div class="mt-8 text-center">
          <Button href="/projects" variant="primary" class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-theme-400 dark:focus-visible:ring-accent-400">View More Projects</Button>
        </div>
      )}
    </div>
  </section>


  {/* --- Blog Section --- */}
  <section id="blog" class="w-full mb-16">
    <div class="max-w-4xl mx-auto px-4 w-full">
      <SectionHeader 
        title="From the Blog"
        description="Recent articles and insights."
        actionButton={{
          text: 'View All',
          href: '/blog',
          variant: 'outline',
        }}
        accent="top"
        accentSize="md">
      </SectionHeader>

      <div class="max-w-3xl mx-auto space-y-4">
        {blogPosts.map(post => (
        <div class="transition-all duration-200 hover:-translate-y-1">
          <BlogPreviewCard post={post} />
        </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { isEnabled } from '../config/flags';

const enabled = isEnabled('showContactPage');
---

{!enabled && (
  <html>
    <head>
      <meta charset="UTF-8" />
      <meta http-equiv="refresh" content="0;url=/" />
    </head>
    <body><script is:inline>window.location.replace('/');</script></body>
  </html>
)}
{enabled && (

<BaseLayout title="Contact" description="Get in touch to discuss engineering work, collaborations, or community projects.">
  <section class="w-full mb-4">
    <div class="max-w-5xl mx-auto px-5 sm:px-6 w-full">
      <div class="max-w-4xl mx-auto py-12 sm:py-16">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-content-strong tracking-tight leading-[1.05] mb-5">
          Get in Touch
        </h1>
        <div class="max-w-2xl space-y-4">
          <p class="text-content text-base sm:text-lg leading-8">
            For engineering work, collaborations, or community projects, send me a message and I will get back to you when I can.
          </p>
          <p class="text-content-muted text-sm sm:text-base leading-7">
            The form is the easiest route. If you are reaching out about backend, platform, or systems-oriented work, a little context upfront helps.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="w-full mb-20">
    <div class="max-w-5xl mx-auto px-5 sm:px-6 w-full">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <span class="text-xs font-mono text-theme-500 dark:text-theme-400 tracking-widest shrink-0">01</span>
          <h2 class="text-2xl font-bold text-content-strong shrink-0">Message</h2>
          <div class="flex-1 h-[2px] bg-border"></div>
        </div>

        <div class="rounded-2xl border border-border bg-surface/85 p-6 shadow-subtle dark:shadow-none sm:p-8 lg:p-10">
          <form id="contact-form" class="max-w-3xl space-y-6">
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
              <div>
                <label for="name" class="mb-2 block text-sm font-medium text-content-strong">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full appearance-none rounded-lg border border-border bg-white px-4 py-2.5 text-content transition-colors duration-200 placeholder:text-content-subtle focus:outline-none focus:ring-2 focus:ring-theme-400 dark:bg-[#111515] dark:focus:ring-theme-400"
                />
              </div>

              <div>
                <label for="email" class="mb-2 block text-sm font-medium text-content-strong">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full appearance-none rounded-lg border border-border bg-white px-4 py-2.5 text-content transition-colors duration-200 placeholder:text-content-subtle focus:outline-none focus:ring-2 focus:ring-theme-400 dark:bg-[#111515] dark:focus:ring-theme-400"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="mb-2 block text-sm font-medium text-content-strong">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                class="w-full appearance-none rounded-lg border border-border bg-white px-4 py-2.5 text-content transition-colors duration-200 placeholder:text-content-subtle focus:outline-none focus:ring-2 focus:ring-theme-400 dark:bg-[#111515] dark:focus:ring-theme-400"
              />
            </div>

            <div>
              <label for="message" class="mb-2 block text-sm font-medium text-content-strong">Message</label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full appearance-none resize-none rounded-lg border border-border bg-white px-4 py-2.5 text-content transition-colors duration-200 placeholder:text-content-subtle focus:outline-none focus:ring-2 focus:ring-theme-400 dark:bg-[#111515] dark:focus:ring-theme-400"
              ></textarea>
            </div>

            <div class="flex flex-col gap-4 border-t border-border-subtle pt-6 sm:flex-row sm:items-center sm:justify-between">
              <div id="form-status" class="hidden text-sm text-content-muted">
                <!-- Status messages will appear here -->
              </div>

              <Button
                type="submit"
                variant="primary"
                size="lg"
                class="self-end"
                id="submit-button"
              >
                Send Message
              </Button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('contact-form') as HTMLFormElement; // Add type assertion
      const statusDiv = document.getElementById('form-status');
      const submitButton = document.getElementById('submit-button') as HTMLButtonElement; // Add type assertion
      
      if (form && statusDiv && submitButton) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          // Show loading state
          submitButton.disabled = true;
          if (statusDiv) { // Add null check for statusDiv
            statusDiv.textContent = 'Sending message...';
            statusDiv.classList.remove('hidden', 'text-red-500', 'text-green-500');
            statusDiv.classList.add('block', 'text-content-muted');
          }
          
          try {
            // Get form data
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            // Call your API here
            // Replace with your actual API endpoint
            // const response = await fetch('https://your-worker.worker.dev/contact', {
            //   method: 'POST',
            //   headers: {
            //     'Content-Type': 'application/json',
            //   },
            //   body: JSON.stringify(data),
            // });
            
            // Simulate API call with a delay
            await new Promise(resolve => setTimeout(resolve, 1000));
            
            // Simulate successful response
            const success = true;
            
            if (success) {
              // Show success message
              if (statusDiv) { // Add null check for statusDiv
                statusDiv.textContent = 'Message sent successfully! I\'ll get back to you soon.';
                statusDiv.classList.remove('text-content-muted', 'text-red-500');
                statusDiv.classList.add('text-green-500');
              }
              
              // Reset form
              form.reset();
            } else {
              // Show error message
              if (statusDiv) { // Add null check for statusDiv
                statusDiv.textContent = 'Failed to send message. Please try again later.';
                statusDiv.classList.remove('text-content-muted', 'text-green-500');
                statusDiv.classList.add('text-red-500');
              }
            }
          } catch (error) {
            console.error('Error sending message:', error);
            
            // Show error message
            if (statusDiv) { // Add null check for statusDiv
              statusDiv.textContent = 'An error occurred. Please try again later.';
              statusDiv.classList.remove('text-content-muted', 'text-green-500');
              statusDiv.classList.add('text-red-500');
            }
          } finally {
            // Enable submit button
            submitButton.disabled = false;
          }
        });
      }
    });
</script>
)}

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import YearSection from '../../components/sections/YearSection.astro';
import { getCollection } from 'astro:content';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { isEnabled } from '../../config/flags';
import { absoluteUrl } from '../../utils/url';

const enabled = isEnabled('showBlogPage');
const compactArchive = isEnabled('useCompactBlogArchive');

const allPosts = (await getCollection('blog'))
  .filter((post) => isEnabled('showDrafts') || !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByYear: Record<string, typeof allPosts> = {};
allPosts.forEach((post) => {
  const year = post.data.pubDate.getFullYear().toString();
  if (!postsByYear[year]) postsByYear[year] = [];
  postsByYear[year].push(post);
});

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog | Joshua Sawyer',
  url: absoluteUrl('/blog', Astro.site),
  description: 'Technical writing on engineering practice, distributed systems, platform work, and tradeoffs from real-world delivery.',
};
---

{!enabled && (
  <html>
    <head>
      <meta charset="UTF-8" />
      <meta http-equiv="refresh" content="0;url=/" />
    </head>
    <body><script is:inline>window.location.replace('/');</script></body>
  </html>
)}
{enabled && (
<BaseLayout
  title="Blog | Joshua Sawyer"
  description="Technical writing on engineering practice, distributed systems, platform work, and tradeoffs from real-world delivery."
  canonicalUrl="/blog"
  structuredData={structuredData}
>
  <section class="w-full mb-4">
    <div class="max-w-5xl mx-auto px-5 sm:px-6 w-full">
      <div class="max-w-4xl mx-auto py-12 sm:py-16">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-content-strong tracking-tight leading-[1.05] mb-5">
          Blog
        </h1>
        <div class="max-w-2xl space-y-4">
          <p class="text-content text-base sm:text-lg leading-8">
            A place for notes, ramblings, and the occasional useful write-up.
          </p>
          <p class="text-content-muted text-sm sm:text-base leading-7">
            Mostly software, systems, and things I have been thinking about, with a few more informal posts mixed in when they seem worth writing down.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="w-full mb-16">
    <div class="max-w-5xl mx-auto px-5 sm:px-6 w-full">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <span class="text-xs font-mono text-theme-500 dark:text-theme-400 tracking-widest shrink-0">01</span>
          <h2 class="text-2xl font-bold text-content-strong shrink-0">Archive</h2>
          <div class="flex-1 h-[2px] bg-border"></div>
          <div class="text-sm text-content-muted shrink-0">{allPosts.length} articles</div>
        </div>
        <div class="mb-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
          <span class="text-content-muted">Jump to</span>
          {years.map((year) => (
            <a href={`#year-${year}`} class="text-content-muted transition-colors hover:text-content">
              {year}
            </a>
          ))}
        </div>
        {compactArchive ? (
          <div class="divide-y divide-border">
            {allPosts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="flex items-center justify-between py-3 px-1 group hover:text-theme-600 dark:hover:text-theme-400 transition-colors duration-200"
              >
                <span class="text-content-strong group-hover:text-theme-600 dark:group-hover:text-theme-400 transition-colors duration-200 text-sm sm:text-base">
                  {post.data.title}
                </span>
                <span class="text-content-muted text-xs sm:text-sm shrink-0 ml-4">
                  {post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
              </a>
            ))}
          </div>
        ) : (
          <div class="p-6 sm:p-8 lg:p-10">
            <div class="space-y-10">
              {years.map((year) => (
                <YearSection year={year} posts={postsByYear[year]} />
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="w-full mb-20">
    <div class="max-w-5xl mx-auto px-5 sm:px-6 w-full">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <span class="text-xs font-mono text-theme-500 dark:text-theme-400 tracking-widest shrink-0">02</span>
          <h2 class="text-2xl font-bold text-content-strong shrink-0">Updates</h2>
          <div class="flex-1 h-[2px] bg-border"></div>
        </div>
        <NewsletterSignup />
      </div>
    </div>
  </section>
</BaseLayout>
)}

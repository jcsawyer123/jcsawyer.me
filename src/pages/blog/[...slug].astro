---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Tag from '../../components/Tag.astro';
import TableOfContents from '../../components/markdown/TableOfContents.astro';
import GlossaryProvider from '../../components/markdown/GlossaryProvider.astro';
import ReadingTime from '../../components/markdown/ReadingTime.astro';
import ShareButtons from '../../components/markdown/ShareButtons.astro';
import Button from '../../components/Button.astro';

// Generate paths for all blog posts
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'> & {
  data: {
    image?: {
      src: string;
      alt?: string;
    };
  };
};

const post = Astro.props;
const { Content, headings } = await post.render(); // Renders the Markdown content and extracts headings

// Fetch related posts based on tags (limit to 2)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug) // Exclude current post
  .filter((p) =>
    p.data.tags.some((tag) =>
      post.data.tags.some((postTag) => postTag.label === tag.label),
    ),
  )
  .sort(() => Math.random() - 0.5) // Randomize selection
  .slice(0, 2);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.image?.src || '/images/blog-default-og.jpg'}
>
  <GlossaryProvider>
    <div class="max-w-6xl mx-auto lg:px-8">
      {/* Back link */}
      <div class="mb-6 mt-8">
        <a
          href="/blog"
          class="inline-flex items-center text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4 mr-1"
          >
            <path
              fill-rule="evenodd"
              d="M18 10a.75.75 0 01-.75.75H4.66l2.1 1.95a.75.75 0 11-1.02 1.1l-3.5-3.25a.75.75 0 010-1.1l3.5-3.25a.75.75 0 111.02 1.1l-2.1 1.95h12.59A.75.75 0 0118 10z"
              clip-rule="evenodd"
            ></path>
          </svg>
          All Articles
        </a>
      </div>

      {/* Mobile Table of Contents (Collapsible) */}
      <div class="mb-8 lg:hidden">
        <details class="group">
          <summary class="flex justify-between items-center cursor-pointer bg-white/80 dark:bg-slate-800/75 border border-slate-200/40 dark:border-slate-700/40 rounded-lg p-4 text-slate-800 dark:text-slate-100 font-semibold">
            <span>Table of Contents</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 group-open:rotate-180 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </summary>
          <div class="mt-3 border border-slate-200/40 dark:border-slate-700/40 rounded-lg p-4 bg-white/80 dark:bg-slate-800/75">
            <TableOfContents headings={headings} />
          </div>
        </details>
      </div>

      {/* Main content with sidebar grid */}
      <div class="md:grid md:grid-cols-[1fr_300px] gap-10">
        {/* Main column */}
        <div>
          <Container
            borderColor="border-slate-200/40 dark:border-slate-700/40"
            class="overflow-hidden relative p-6 sm:p-8 lg:p-10 rounded-xl shadow-sm max-w-3xl mx-auto lg:max-w-none bg-white/80 dark:bg-slate-800/75 backdrop-blur-md border"
          >

            {/* Post header */}
            <div class="mb-8 relative z-10">
              {post.data.image && (
                <div class="mb-6 -mx-6 sm:-mx-8 lg:-mx-10 overflow-hidden">
                  <img
                    src={post.data.image.src}
                    alt={post.data.image.alt || post.data.title}
                    class="w-full h-auto object-cover rounded-lg"
                  />
                </div>
              )}

              <h1 class="text-3xl lg:text-4xl font-bold text-slate-800 dark:text-slate-100 mb-4 leading-tight">
                {post.data.title}
              </h1>

              <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
                {/* Author info if available */}
                {post.data.author && (
                  <div class="flex items-center">
                    {post.data.author.avatar && (
                      <img
                        src={post.data.author.avatar}
                        alt={post.data.author.name}
                        class="w-8 h-8 rounded-full mr-2"
                      />
                    )}
                    <span class="text-slate-700 dark:text-slate-300">
                      {post.data.author.name}
                    </span>
                  </div>
                )}

                {/* Date */}
                <div class="text-slate-500 dark:text-slate-400 flex items-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-4 h-4 mr-1"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75.75 0 014.75 4H5V2.75A.75.75 0 015.75 2zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </div>

                {/* Reading time */}
                <ReadingTime content={post.body} />
              </div>

              {/* Tags */}
              <div class="flex flex-wrap gap-2 mt-4">
                {post.data.tags.map((tag) => (
                  <Tag label={tag.label} color={tag.color} />
                ))}
              </div>
            </div>

            {/* Content divider */}
            <div class="border-t-2 border-slate-200 dark:border-slate-700 mb-8 relative z-10"></div>

            {/* Article content */}
            <article class="prose prose-slate dark:prose-invert lg:prose-lg max-w-none relative z-10">
              <Content />
            </article>

            {/* Share section */}
            <div class="mt-10 pt-6 border-t-2 border-slate-200 dark:border-slate-700 relative z-10">
              <ShareButtons
                title={post.data.title}
                url={`/blog/${post.slug}`}
              />
            </div>
          </Container>

          {/* Related posts section */}
          {relatedPosts.length > 0 && (
            <div class="mt-12 mb-16">
              <h2 class="text-xl font-bold text-slate-800 dark:text-slate-100 mb-6">
                You might also like
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                {relatedPosts.map((relatedPost) => (
                  <a href={`/blog/${relatedPost.slug}`} class="group">
                    <Container
                      borderColor="border-slate-200/40 dark:border-slate-700/40"
                      class="overflow-hidden p-5 rounded-xl h-full transition-transform duration-200 hover:-translate-y-1 hover:shadow-lg bg-white/80 dark:bg-slate-800/75 backdrop-blur-md border shadow-sm"
                    >
                      {relatedPost.data.image && (
                        <div class="mb-4 overflow-hidden rounded-lg">
                          <img
                            src={relatedPost.data.image.src}
                            alt={
                              relatedPost.data.image.alt ||
                              relatedPost.data.title
                            }
                            class="w-full h-32 object-cover group-hover:scale-105 transition duration-300"
                          />
                        </div>
                      )}
                      <h3 class="font-semibold text-slate-800 dark:text-slate-100 mb-1 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition">
                        {relatedPost.data.title}
                      </h3>
                      <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">
                        {relatedPost.data.description}
                      </p>
                    </Container>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Mobile Newsletter Signup */}
          <div class="lg:hidden mb-16 mt-8">
            <Container
              borderColor="border-slate-200/40 dark:border-slate-700/40"
              class="relative overflow-hidden p-8 bg-white/80 dark:bg-slate-800/75 backdrop-blur-md border shadow-sm rounded-xl"
            >
              {/* Gradient Accent Bar */}
              <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-sky-300 to-blue-400 dark:from-blue-600 dark:to-purple-700" aria-hidden="true"></div>
              <div class="relative z-10 pt-2">
                <h3 class="text-lg font-semibold text-slate-800 dark:text-slate-100 mb-3">
                  Stay updated
                </h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
                  Get notified when new articles are published
                </p>
                <form class="space-y-2">
                  <input
                    type="email"
                    placeholder="Your email"
                    class="w-full px-3 py-2 border-2 border-slate-300 dark:border-slate-600 rounded-md bg-white/80 dark:bg-slate-800/75 text-slate-800 dark:text-slate-200 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-sky-400 dark:focus:ring-blue-500"
                    required
                  />
                  <Button type="submit" variant="primary" class="w-full">Subscribe</Button>
                </form>
              </div>
            </Container>
          </div>
        </div>

        {/* Sidebar column */}
        <div class="hidden lg:block">
          <div class="sticky top-24 space-y-6">
            <Container
              borderColor="border-slate-200/40 dark:border-slate-700/40"
              class="relative overflow-hidden p-6 rounded-xl mb-6 bg-white/80 dark:bg-slate-800/75 backdrop-blur-md border shadow-sm"
            >
              {/* Gradient Accent Bar */}
              <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-sky-300 to-blue-400 dark:from-blue-600 dark:to-purple-700" aria-hidden="true"></div>
              <div class="relative z-10 pt-2">
                <h3 class="text-lg font-semibold text-slate-800 dark:text-slate-100 mb-4">
                  Table of Contents
                </h3>
                <TableOfContents headings={headings} />
              </div>
            </Container>

            {/* Newsletter in sidebar */}
            <Container
              borderColor="border-slate-200/40 dark:border-slate-700/40"
              class="relative overflow-hidden p-6 rounded-xl bg-white/80 dark:bg-slate-800/75 backdrop-blur-md border shadow-sm"
            >
              {/* Gradient Accent Bar */}
              <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-sky-300 to-blue-400 dark:from-blue-600 dark:to-purple-700" aria-hidden="true"></div>
              <div class="relative z-10 pt-2">
                <h3 class="text-lg font-semibold text-slate-800 dark:text-slate-100 mb-3">
                  Stay updated
                </h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">
                  Get notified when new articles are published
                </p>
                <form class="space-y-2">
                  <input
                    type="email"
                    placeholder="Your email"
                    class="w-full px-3 py-2 border-2 border-slate-300 dark:border-slate-600 rounded-md bg-white/80 dark:bg-slate-800/75 text-slate-800 dark:text-slate-200 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-sky-400 dark:focus:ring-blue-500"
                    required
                  />
                  <Button type="submit" variant="primary" class="w-full">Subscribe</Button>
                </form>
              </div>
            </Container>
          </div>
        </div>
      </div>
    </div>
  </GlossaryProvider>
</BaseLayout>

<script>
  // Highlight current section in Table of Contents based on scroll position
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            document.querySelectorAll('.toc-link').forEach((link) => {
              link.classList.remove('active');
            });
            document
              .querySelector(`.toc-link[href="#${id}"]`)
              ?.classList.add('active');
          }
        });
      },
      { rootMargin: '0px 0px -80% 0px', threshold: 0.1 },
    );

    // Observe all headings
    document.querySelectorAll('article h2, article h3').forEach((heading) => {
      observer.observe(heading);
    });
  });
</script>

<style>
  .toc-link.active {
    @apply text-blue-600 dark:text-blue-400 font-medium;
  }
  html {
    scroll-behavior: smooth;
  }
</style>

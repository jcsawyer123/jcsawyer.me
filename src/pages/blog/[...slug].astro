---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tag from '../../components/Tag.astro';
import TableOfContents from '../../components/markdown/TableOfContents.astro';
import GlossaryProvider from '../../components/markdown/GlossaryProvider.astro';
import ReadingTime from '../../components/markdown/ReadingTime.astro';
import ShareButtons from '../../components/markdown/ShareButtons.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import GradientAccent from '../../components/GradientAccent.astro';

// Generate paths for all blog posts
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'> & {
  data: {
    image?: {
      src: string;
      alt?: string;
    };
  };
};

const post = Astro.props as Props;
const { Content, headings } = await post.render(); // Renders the Markdown content and extracts headings

// Robust shuffle function
function shuffle<T>(array: T[]): T[] {
  let arr = array.slice();
  let currentIndex = arr.length, randomIndex;
  while (currentIndex !== 0) {
    randomIndex = Math.floor(Math.random() * currentIndex);
    currentIndex--;
    [arr[currentIndex], arr[randomIndex]] = [arr[randomIndex], arr[currentIndex]];
  }
  return arr;
}

// Fetch related posts based on tags (limit to 2)
const allPosts = await getCollection('blog');
const relatedPosts = shuffle(
  allPosts
    .filter((p) => p.slug !== post.slug)
    .filter((p) =>
      p.data.tags?.some((tag) =>
        post.data.tags?.some((postTag) => postTag.label === tag.label),
      ),
    )
).slice(0, 2);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.image?.src || '/images/blog-default-og.jpg'}
>
  <GlossaryProvider>
    <div class="mx-auto px-1 md:px-6 max-w-[1600px]">
      {/* Back link */}
      <div class="mb-6 mt-8">
        <a
          href="/blog"
          class="inline-flex items-center text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4 mr-1"
            aria-hidden="true"
          >
            <path
              fillRule="evenodd"
              d="M18 10a.75.75 0 01-.75.75H4.66l2.1 1.95a.75.75 0 11-1.02 1.1l-3.5-3.25a.75.75 0 010-1.1l3.5-3.25a.75.75 0 111.02 1.1l-2.1 1.95h12.59A.75.75 0 0118 10z"
              clipRule="evenodd"
            ></path>
          </svg>
          All Articles
        </a>
      </div>

      {/* Mobile Table of Contents (Collapsible) */}
      <div class="mb-8 xl:hidden max-w-4xl mx-auto">
        <details class="group">
          <summary class="flex justify-between rounded-lg items-center cursor-pointer frosted panel border border-slate-300 dark:border-slate-700 p-4 text-slate-800 dark:text-slate-100 font-semibold">
            <span>Table of Contents</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 group-open:rotate-180 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </summary>
          <div class="mt-3 frosted panel border border-slate-300 dark:border-slate-700 p-4">
            <TableOfContents headings={headings} />
          </div>
        </details>
      </div>

      {/* Main content with sidebar grid */}
      <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_330px] gap-6 xl:gap-10 mb-2">
        {/* Main column */}
        <div>
          <div class="relative overflow-hidden p-3 sm:p-6 md:p-8 xl:p-10 rounded-xl shadow-sm max-w-4xl mx-auto xl:max-w-none frosted panel border border-slate-300 dark:border-slate-700">
            {/* Post header */}
            <div class="mb-6 md:mb-8 relative pt-4 z-10">
              {post.data.image && (
                <div class="mb-4 md:mb-6 -mx-3 sm:-mx-6 md:-mx-8 xl:-mx-10 overflow-hidden">
                  <img
                    src={post.data.image.src}
                    alt={post.data.image.alt || post.data.title}
                    class="w-full h-auto object-cover rounded-lg"
                  />
                </div>
              )}

              <h1 class="heading-1 mb-4 leading-tight">
                {post.data.title}
              </h1>

              <div class="flex flex-wrap items-center gap-x-4 sm:gap-x-6 gap-y-3 text-sm">
                {/* Author info if available */}
                {post.data.author && (
                  <div class="flex items-center">
                    {post.data.author.avatar && (
                      <img
                        src={post.data.author.avatar}
                        alt={post.data.author.name}
                        class="w-8 h-8 rounded-full mr-2"
                      />
                    )}
                    <span class="text-slate-700 dark:text-slate-300">
                      {post.data.author.name}
                    </span>
                  </div>
                )}

                {/* Date */}
                <div class="caption-text flex items-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-4 h-4 mr-1"
                    aria-hidden="true"
                  >
                    <path
                      fillRule="evenodd"
                      d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75.75 0 014.75 4H5V2.75A.75.75 0 015.75 2zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75z"
                      clipRule="evenodd"
                    />
                  </svg>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </div>

                {/* Reading time */}
                <ReadingTime content={post.body} />
              </div>

              {/* Tags */}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {post.data.tags.map((tag) => (
                    <Tag label={tag.label} color={tag.color} />
                  ))}
                </div>
              )}
            </div>

            {/* Content divider */}
            <div class="border-t-2 border-slate-200 dark:border-slate-700 mb-6 md:mb-8 relative z-10"></div>

            {/* Article content */}
            <article class="prose prose-slate dark:prose-invert lg:prose-lg max-w-none relative z-10 dark:text-slate-200 mobile-article-content">
              <Content />
            </article>

            {/* Share section */}
            <div class="mt-8 md:mt-10 pt-6 border-t-2 border-slate-200 dark:border-slate-700 relative z-10">
              <ShareButtons
                title={post.data.title}
                url={`/blog/${post.slug}`}
              />
            </div>
          </div>

          {/* Related posts section */}
          {relatedPosts.length > 0 && (
            <div class="mt-8 md:mt-12 mb-10 md:mb-16">
              <h2 class="heading-3 mb-4 md:mb-6">
                You might also like
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
                {relatedPosts.map((relatedPost) => (
                  <a href={`/blog/${relatedPost.slug}`} class="group hover-lift">
                    <div class="frosted panel border border-slate-300 dark:border-slate-700 h-full p-4 md:p-5">
                      {relatedPost.data.image && (
                        <div class="mb-3 md:mb-4 overflow-hidden rounded-lg">
                          <img
                            src={relatedPost.data.image.src}
                            alt={
                              relatedPost.data.image.alt ||
                              relatedPost.data.title
                            }
                            class="w-full h-32 object-cover group-hover:scale-105 transition duration-300"
                          />
                        </div>
                      )}
                      <h3 class="font-semibold text-slate-800 dark:text-slate-100 mb-1 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition">
                        {relatedPost.data.title}
                      </h3>
                      <p class="text-sm text-slate-600 dark:text-slate-300 line-clamp-2">
                        {relatedPost.data.description}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Mobile Newsletter Signup */}
          <NewsletterSignup className="xl:hidden max-w-4xl mx-auto mb-10 md:mb-4 mt-6 md:mt-8" />
        </div>

        {/* Sidebar column */}
        <aside class="hidden xl:block">
          <div class="sticky top-24 space-y-6">
            <div class="relative overflow-hidden p-6 rounded-xl mb-6 frosted panel border border-slate-300 dark:border-slate-700">
              <GradientAccent position="top" size="md" />
              <div class="relative z-10 pt-2">
                <h3 class="heading-3 mb-4">
                  Table of Contents
                </h3>
                <TableOfContents headings={headings} />
              </div>
            </div>
            <NewsletterSignup />
          </div>
        </aside>
      </div>
    </div>
  </GlossaryProvider>
</BaseLayout>

<script>
  // Highlight current section in Table of Contents based on scroll position
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            document.querySelectorAll('.toc-link').forEach((link) => {
              link.classList.remove('active');
            });
            document
              .querySelector(`.toc-link[href="#${id}"]`)
              ?.classList.add('active');
          }
        });
      },
      { rootMargin: '0px 0px -80% 0px', threshold: 0.1 },
    );

    // Observe all headings
    document.querySelectorAll('article h2, article h3').forEach((heading) => {
      observer.observe(heading);
    });
  });
</script>

<style>
  .toc-link.active {
    @apply text-blue-600 dark:text-blue-400 font-medium;
  }
  
  /* Improved dark mode text readability */
  .dark .prose p,
  .dark .prose li,
  .dark .prose td {
    @apply text-slate-200;
  }
  
  .dark .prose a {
    @apply text-blue-300 hover:text-blue-200;
  }
  
  .dark .prose strong {
    @apply text-slate-100;
  }
  
  .dark .prose h2,
  .dark .prose h3,
  .dark .prose h4 {
    @apply text-slate-100;
  }
  
  .dark .prose blockquote {
    @apply border-slate-600 text-slate-300;
  }
  
  .dark .prose code {
    @apply bg-slate-700 text-slate-200;
  }
  
  /* Optimize article content for mobile readability */
  @media (max-width: 640px) {
    .mobile-article-content {
      padding-left: 0;
      padding-right: 0;
    }
    .mobile-article-content h2,
    .mobile-article-content h3,
    .mobile-article-content h4 {
      margin-top: 1.5em;
      margin-bottom: 0.75em;
    }
    .mobile-article-content p,
    .mobile-article-content ul,
    .mobile-article-content ol {
      margin-top: 0.75em;
      margin-bottom: 0.75em;
    }
    .mobile-article-content pre {
      margin: 1em -0.5em;
      padding: 1em 0.5em;
      border-radius: 0.25rem;
    }
  }
</style>

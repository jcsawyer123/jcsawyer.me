---
interface Props {
	code: string;
	language?: string;
	class?: string;
}

const { code, language = 'jsx', class: className } = Astro.props;
---

<div class:list={[
	'panel frosted frosted-heavy rounded-lg overflow-hidden shadow-sm',
	className
]}>
	{language && (
		<div class="px-4 py-1.5 bg-slate-200/80 dark:bg-slate-700/80 border-b border-adaptive font-mono text-xs text-adaptive">
			{language}
		</div>
	)}
	<pre class="p-4 overflow-x-auto"><code class="text-sm font-mono text-adaptive-strong background-none">{code}</code></pre>
</div>
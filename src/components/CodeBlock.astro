---
interface Props {
	code: string;
	language?: string;
	class?: string;
}

const { code, language = 'jsx', class: className } = Astro.props;
---

<div class:list={['bg-slate-100 dark:bg-slate-800 rounded-lg overflow-hidden shadow-sm border border-slate-200 dark:border-slate-700', className]}>
	{language && (
		<div class="px-4 py-1.5 bg-slate-200 dark:bg-slate-700 border-b border-slate-300 dark:border-slate-600 font-mono text-xs text-slate-600 dark:text-slate-200">
			{language}
		</div>
	)}
	<pre class="p-4 overflow-x-auto"><code class="text-sm font-mono text-slate-800">{code}</code></pre>
</div>

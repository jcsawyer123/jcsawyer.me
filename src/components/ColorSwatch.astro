---
interface Props {
	color: string; // e.g., "bg-blue-500"
	name: string;
	hex: string;
}

const { color, name, hex } = Astro.props;
---

<div class="flex flex-col items-center text-center">
	<div class:list={[color, 'h-20 w-20 rounded-lg shadow-md mb-2 border border-slate-200 dark:border-slate-700']}></div>
	<span class="font-medium text-slate-800 dark:text-slate-200 text-sm">{name}</span>
	<span class="text-xs text-slate-500 dark:text-slate-400 font-mono">{hex}</span>
</div>

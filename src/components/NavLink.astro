---
interface Props {
	href: string;
	active?: boolean;
}
const { href, active = false } = Astro.props;
---

	<a
	href={href}
	class:list={[
		'px-2 py-1',
		'text-content hover:text-content-strong dark:text-content-muted dark:hover:text-content',
		'font-medium',
		'transition-colors duration-200',
		{ 'text-content-strong font-semibold': active },
	]}
>
	<slot />
	{active && (
		<span class="block mt-0.5 h-0.5 bg-gradient-to-r from-theme-300 to-theme-500 dark:from-theme-700 dark:to-theme-500 rounded-full"></span>
	)}
</a>

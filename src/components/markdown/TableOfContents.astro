---
export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Filter headings to only include h2 and h3
const filteredHeadings = headings.filter(
  heading => heading.depth === 2 || heading.depth === 3
);
---

{filteredHeadings.length > 0 && (
  <nav class="toc text-sm">
    <ul class="space-y-2">
      {filteredHeadings.map(heading => (
        <li class={`${heading.depth === 3 ? "ml-4" : ""}`}>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'toc-link block py-1 transition-colors duration-200',
              'text-content-muted hover:text-theme-700 dark:text-content-subtle dark:hover:text-theme-300',
              heading.depth === 3 && 'border-l-2 border-border pl-2'
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc-link.active {
    @apply text-theme-700 dark:text-theme-300 font-medium;
  }

  .toc-link.active:is([class*="border-l-2"]) {
    @apply border-theme-600 dark:border-theme-400;
  }
</style>

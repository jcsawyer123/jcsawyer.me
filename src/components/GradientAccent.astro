---
interface Props {
  position?: 'top' | 'left' | 'right' | 'bottom';
  size?: 'sm' | 'md' | 'lg';
  direction?: 'r' | 'l' | 'b' | 't';
  class?: string;
}

const { 
  position = 'top', 
  size = 'md',
  direction,
  class: className 
} = Astro.props;

// Position classes
const positionMap = {
  top: 'top-0 left-0 w-full',
  left: 'left-0 top-0 bottom-0',
  right: 'right-0 top-0 bottom-0',
  bottom: 'bottom-0 left-0 w-full',
};

// Size classes
const sizeMap = {
  sm: position === 'left' || position === 'right' ? 'w-1' : 'h-1',
  md: position === 'left' || position === 'right' ? 'w-2' : 'h-2',
  lg: position === 'left' || position === 'right' ? 'w-3' : 'h-3',
};

// Direction classes (defaults based on position if not specified)
const getDirection = () => {
  if (direction) return `bg-gradient-to-${direction}`;
  
  const defaultDirections = {
    top: 'bg-gradient-to-r',
    left: 'bg-gradient-to-b',
    right: 'bg-gradient-to-b',
    bottom: 'bg-gradient-to-r',
  };
  
  return defaultDirections[position];
};
---

<div
  class:list={[
    'absolute',
    positionMap[position],
    sizeMap[size],
    getDirection(),
    'from-theme-300 to-theme-400 dark:from-theme-600 dark:to-accent-700',
    className
  ]}
  aria-hidden="true"
></div>
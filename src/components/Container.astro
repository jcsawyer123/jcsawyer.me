---
import type { ContainerProps } from '../types/props';

type Props = ContainerProps;

const {
  frosted = false,
  panel = false,
  borderColor,
  rounded = 'xl',
  padding = 'md',
  class: className,
  id,
} = Astro.props;

// Mapping for rounded classes
const roundedMap = {
  'sm': 'rounded-sm',
  'md': 'rounded-md',
  'lg': 'rounded-lg',
  'xl': 'rounded-xl',
  '2xl': 'rounded-2xl',
  '3xl': 'rounded-3xl',
  'full': 'rounded-full',
};

const roundedClass = roundedMap[rounded];
const paddingClass = `panel-padding-${padding}`;

// Build conditional classes
const containerClasses = [
  panel && 'panel',
  frosted && 'frosted frosted-light',
  borderColor || (panel && 'border-adaptive'),
  roundedClass,
  paddingClass,
  'transition-standard',
  className
];
---

<div
  id={id}
  class:list={containerClasses}
>
  <slot />
</div>
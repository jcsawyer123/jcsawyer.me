---
import type { ContainerProps } from '../types/props';

type Props = ContainerProps;

const {
  frosted = false,
  panel = false,
  borderColor,
  rounded = 'xl',
  class: className,
  id,
} = Astro.props;

// Mapping for rounded classes
const roundedMap = {
  'sm': 'rounded-sm',
  'md': 'rounded-md',
  'lg': 'rounded-lg',
  'xl': 'rounded-xl',
  '2xl': 'rounded-2xl',
  '3xl': 'rounded-3xl',
  'full': 'rounded-full',
};

const roundedClass = roundedMap[rounded];

// Build conditional classes
const containerClasses = [
  panel && 'border border-border shadow-default relative overflow-hidden',
  frosted && 'backdrop-blur-md bg-surface-muted',
  borderColor || (panel && borderColor),
  roundedClass,
  'transition-all duration-200',
  className
];
---

<div
  id={id}
  class:list={containerClasses}
>
  <slot />
</div>
---
interface Props {
	borderColor?: string;
	rounded?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | 'full';
	class?: string;
}
const {
	borderColor = 'border-slate-700 dark:border-slate-600',
	rounded = 'xl',
	class: className,
} = Astro.props;
const roundedClass = `rounded-${rounded}`;
---

<div
	class:list={[
		'bg-white dark:bg-slate-800',
		'border-2',
		borderColor,
		roundedClass,
		'p-6',
		'transition-colors duration-300',
		className,
	]}
>
	<slot />
</div>

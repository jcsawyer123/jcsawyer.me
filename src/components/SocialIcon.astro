---
interface Props {
  label: string;
  href: string;
  'aria-label'?: string;
  title?: string;
}

const { label, href, 'aria-label': ariaLabelProp, title: titleProp } = Astro.props;

// Map shorthands and full names to canonical names and SVGs
const SOCIALS: Record<string, { name: string; svg: string | null }> = {
  GH: { name: "GitHub", svg: /* svg code below */ `
    <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-content-strong dark:text-content">
      <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.892 1.53 2.341 1.088 2.91.832.091-.647.35-1.088.636-1.339-2.221-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.987 1.029-2.686-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.1 2.65.64.699 1.028 1.593 1.028 2.686 0 3.847-2.337 4.695-4.566 4.944.359.309.678.919.678 1.852 0 1.336-.012 2.417-.012 2.747 0 .267.18.577.688.479C19.138 20.2 22 16.448 22 12.021 22 6.484 17.523 2 12 2z"/>
    </svg>
  ` },
  GITHUB: { name: "GitHub", svg: /* same as above */ null }, // Will be filled below
  //////////////////////
  LI: { name: "LinkedIn", svg: /* svg code below */ `
    <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-content-strong dark:text-content">
      <path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11 19h-3v-9h3v9zm-1.5-10.28c-.97 0-1.75-.79-1.75-1.75s.78-1.75 1.75-1.75 1.75.79 1.75 1.75-.78 1.75-1.75 1.75zm13.5 10.28h-3v-4.5c0-1.08-.02-2.47-1.5-2.47-1.5 0-1.73 1.17-1.73 2.38v4.59h-3v-9h2.89v1.23h.04c.4-.75 1.38-1.54 2.84-1.54 3.04 0 3.6 2 3.6 4.59v4.72z"/>
    </svg>
  ` },
  LINKEDIN: { name: "LinkedIn", svg: /* same as above */ null },
  /////////////////////
  TW: { name: "Twitter", svg: /* svg code below */ `
    <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-content-strong dark:text-content">
      <path d="M24 4.557a9.93 9.93 0 01-2.828.775 4.932 4.932 0 002.165-2.724c-.951.564-2.005.974-3.127 1.195a4.92 4.92 0 00-8.384 4.482C7.691 8.095 4.066 6.13 1.64 3.161c-.542.929-.888 2.01-.888 3.17 0 2.188 1.115 4.116 2.823 5.247a4.904 4.904 0 01-2.229-.616c-.054 2.281 1.581 4.415 3.949 4.89a4.936 4.936 0 01-2.224.084c.627 1.956 2.444 3.377 4.6 3.417A9.867 9.867 0 010 21.543a13.94 13.94 0 007.548 2.209c9.058 0 14.009-7.496 14.009-13.986 0-.21-.005-.423-.015-.634A9.936 9.936 0 0024 4.557z"/>
    </svg>
  ` },
  TWITTER: { name: "Twitter", svg: /* same as above */ null },
};

// Fill in full names with the same SVG as their shorthand
SOCIALS.GITHUB.svg = SOCIALS.GH.svg;
SOCIALS.LINKEDIN.svg = SOCIALS.LI.svg;
SOCIALS.TWITTER.svg = SOCIALS.TW.svg;

// Normalize label for lookup
const normalized = label.trim().toUpperCase();
const social = SOCIALS[normalized] || SOCIALS[label.trim().toUpperCase().replace(/\s/g, '')];

// Fallbacks
const displayName = social?.name || label;
const iconSVG = social?.svg;

// aria-label and title logic
const ariaLabel = ariaLabelProp || displayName;
const title = titleProp || displayName;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group"
  aria-label={ariaLabel}
  title={title}
>
  <div
    class="w-8 h-8 border border-border/70 bg-surface-muted rounded-xl flex items-center justify-center shadow-subtle group-hover:border-theme-300 group-hover:bg-surface-subtle dark:group-hover:border-theme-700 dark:group-hover:bg-surface-emphasis transition-colors duration-200"
    role="img"
    aria-hidden="true"
  >
    {iconSVG ? (
      <Fragment set:html={iconSVG} />
    ) : (
      <span class="text-xs font-medium text-content-strong dark:text-content">{label}</span>
    )}
  </div>
</a>

---
interface Props {
	label: string;
	color?: 'blue' | 'green' | 'purple' | 'yellow' | 'red' | 'indigo';
}
const { label, color = 'blue' } = Astro.props;

// Define separate maps for light and dark for clarity
const lightColorMap = {
	blue: 'bg-theme-100 text-theme-800 border border-theme-200',
	green: 'bg-theme-50 text-theme-800 border border-theme-200',
	purple: 'bg-theme-50 text-content border border-border',
	yellow: 'bg-theme-50 text-content border border-border',
	red: 'bg-accent-50 text-accent-800 border border-accent-200',
	indigo: 'bg-surface-subtle text-content border border-border',
};
const darkColorMap = {
    blue: 'dark:bg-surface-emphasis dark:text-content dark:border-border',
    green: 'dark:bg-theme-900/30 dark:text-theme-300 dark:border-theme-800',
    purple: 'dark:bg-surface-emphasis dark:text-content dark:border-border',
    yellow: 'dark:bg-surface-emphasis dark:text-content dark:border-border',
    red: 'dark:bg-accent-950/60 dark:text-accent-300 dark:border-accent-900',
    indigo: 'dark:bg-surface-emphasis dark:text-content dark:border-border',
}

const lightClass = lightColorMap[color] || lightColorMap.blue;
const darkClass = darkColorMap[color] || darkColorMap.blue;
---

<span
	class:list={[
		'inline-block px-2 py-0.5 rounded-full text-xs font-medium transition-colors duration-200',
		lightClass,
        darkClass,
	]}
>
	{label}
</span>

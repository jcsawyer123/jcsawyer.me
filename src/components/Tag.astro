---
interface Props {
	label: string;
	color?: 'blue' | 'green' | 'purple' | 'yellow' | 'red' | 'indigo';
}
const { label, color = 'blue' } = Astro.props;

// Define separate maps for light and dark for clarity
const lightColorMap = {
	blue: 'bg-blue-100 text-blue-800',
	green: 'bg-green-100 text-green-800',
	purple: 'bg-purple-100 text-purple-800',
	yellow: 'bg-yellow-100 text-yellow-800',
	red: 'bg-red-100 text-red-800',
	indigo: 'bg-indigo-100 text-indigo-800',
};
const darkColorMap = {
    blue: 'dark:bg-blue-900/50 dark:text-blue-300',
    green: 'dark:bg-green-900/50 dark:text-green-300',
    purple: 'dark:bg-purple-900/50 dark:text-purple-300',
    yellow: 'dark:bg-yellow-900/50 dark:text-yellow-300',
    red: 'dark:bg-red-900/50 dark:text-red-300',
    indigo: 'dark:bg-indigo-900/50 dark:text-indigo-300',
}

const lightClass = lightColorMap[color] || lightColorMap.blue;
const darkClass = darkColorMap[color] || darkColorMap.blue;
---

<span
	class:list={[
		'inline-block px-2 py-0.5 rounded-full text-xs font-medium',
		lightClass,
        darkClass,
	]}
>
	{label}
</span>

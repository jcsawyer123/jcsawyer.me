---
interface Props {
	label: string;
	color?: 'blue' | 'green' | 'purple' | 'yellow' | 'red' | 'indigo';
}
const { label, color = 'blue' } = Astro.props;

// Light: light fill, dark text. Dark: inverted — saturated fill, light text.
const lightColorMap = {
	blue:   'bg-theme-100 text-theme-800 border border-theme-200',
	green:  'bg-theme-50 text-theme-800 border border-theme-200',
	purple: 'bg-surface-subtle text-content border border-border',
	yellow: 'bg-surface-subtle text-content border border-border',
	red:    'bg-surface-subtle text-content border border-border',
	indigo: 'bg-theme-50 text-theme-800 border border-theme-200',
};
const darkColorMap = {
    blue:   'dark:bg-theme-700 dark:text-theme-100 dark:border-theme-600',
    green:  'dark:bg-theme-700 dark:text-theme-100 dark:border-theme-600',
    purple: 'dark:bg-theme-800 dark:text-theme-200 dark:border-theme-700',
    yellow: 'dark:bg-theme-800 dark:text-theme-200 dark:border-theme-700',
    red:    'dark:bg-theme-800 dark:text-theme-200 dark:border-theme-700',
    indigo: 'dark:bg-theme-700 dark:text-theme-100 dark:border-theme-600',
};

const lightClass = lightColorMap[color] || lightColorMap.blue;
const darkClass = darkColorMap[color] || darkColorMap.blue;
---

<span
	class:list={[
		'inline-block px-2 py-0.5 rounded-full text-xs font-medium transition-colors duration-200',
		lightClass,
        darkClass,
	]}
>
	{label}
</span>

---
import Container from './Container.astro';
import FooterLink from './FooterLink.astro';
import SocialIcon from './SocialIcon.astro';

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="w-full py-8 px-4">
	<div class="max-w-4xl mx-auto">
	  <Container
		borderColor="border border-slate-200 dark:border-slate-600"
		class="rounded-2xl shadow-md bg-white/80 dark:bg-slate-800/80 backdrop-blur-md py-4"
	  >
		<div class="flex flex-col sm:flex-row justify-between items-center gap-4">
		  <div class="text-sm text-slate-600 dark:text-slate-400">
			&copy; {currentYear} Joshua Sawyer. All rights reserved.
		  </div>
		  <div class="flex items-center gap-4">
			<div class="flex gap-4 text-sm text-slate-600">
			  <FooterLink href="/privacy">Privacy</FooterLink>
			  <span class="text-slate-300 dark:text-slate-600">|</span>
			  <FooterLink href="/terms">Terms</FooterLink>
			  <span class="text-slate-300 dark:text-slate-600">|</span>
			  <FooterLink href="/contact">Contact</FooterLink>
			</div>
			<div class="h-8 border-l border-slate-300 dark:border-slate-600"></div>
			<div class="flex gap-2">
			  <SocialIcon label="GH" href="https://github.com" />
			  <SocialIcon label="LI" href="https://linkedin.com" />
			</div>
		  </div>
		</div>
	  </Container>
	</div>
  </footer>
  
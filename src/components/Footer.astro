---
import FooterLink from './FooterLink.astro';
import SocialIcon from './SocialIcon.astro';
import { isEnabled } from '../config/flags';

const currentYear = new Date().getFullYear();
const showContactPage = isEnabled('showContactPage');
---

<footer id="contact" class="w-full py-8 px-4">
	<div class="max-w-5xl mx-auto px-0 w-full">
	  <div class="border border-border shadow-subtle dark:shadow-none backdrop-blur-md bg-surface-muted rounded-2xl p-panel-sm py-4">
		<div class="flex flex-col sm:flex-row justify-between items-center gap-4">
		  <div class="text-sm text-content-muted">
			&copy; {currentYear} Joshua Sawyer. All rights reserved.
		  </div>
		  <div class="flex items-center gap-4">
			{showContactPage && (
			  <>
				<div class="flex gap-4 text-sm text-content-muted">
				  <FooterLink href="/contact">Contact</FooterLink>
				</div>
				<span class="text-border">|</span>
			  </>
			)}
			<div class="flex gap-2">
			  <SocialIcon label="GH" href="https://github.com/jcsawyer123" />
			  <SocialIcon label="LI" href="https://www.linkedin.com/in/joshua-sawyer/" />
			</div>
		  </div>
		</div>
	  </div>
	</div>
</footer>

---
interface Props {
	variant?: 'primary' | 'secondary' | 'outline' | 'highlight';
	href?: string;
	type?: 'button' | 'submit' | 'reset';
	class?: string;
}
const {
	variant = 'primary',
	href,
	type = 'button',
	class: className,
} = Astro.props;

const baseStyles =
	'inline-block px-4 py-2 rounded-lg font-medium transition-all duration-200 text-center focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-slate-900';

const variantStyles = {
	primary: 'bg-slate-800 dark:bg-slate-100 text-white dark:text-slate-800 hover:bg-slate-700 dark:hover:bg-slate-300 focus:ring-slate-500 dark:focus:ring-blue-400',
	secondary: 'bg-slate-200 dark:bg-slate-700 text-slate-800 dark:text-slate-200 hover:bg-slate-300 dark:hover:bg-slate-600 focus:ring-slate-400 dark:focus:ring-slate-500',
	outline:
		'bg-transparent border-2 border-slate-800 dark:border-slate-300 text-slate-800 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-700 focus:ring-slate-500 dark:focus:ring-slate-400',
	highlight: 'bg-blue-200 dark:bg-blue-800/60 text-slate-800 dark:text-slate-200 hover:bg-blue-300 dark:hover:bg-blue-700/60 focus:ring-blue-400 dark:focus:ring-blue-500',
};

const Tag = href ? 'a' : 'button';
const props = href ? { href } : { type };
---

<Tag
	{...props}
	class:list={[baseStyles, variantStyles[variant], className]}
>
	<slot />
</Tag>

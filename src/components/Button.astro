---
import type { ButtonProps } from '../types/props';

type Props = ButtonProps;

const {
  variant = 'primary',
  size = 'md',
  href,
  class: className,
  disabled = false,
  ariaLabel,
  type = 'button', // Default value for type
} = Astro.props;

// Base styles for all buttons
const baseStyles =
  'inline-block font-medium transition-all duration-200 text-center focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-slate-900';

// Size variations
const sizeStyles = {
  sm: 'px-3 py-1 text-sm rounded-md',
  md: 'px-4 py-2 rounded-lg',
  lg: 'px-5 py-2.5 text-lg rounded-xl',
};

// Variant styles
const variantStyles = {
  primary: 'bg-slate-800 dark:bg-slate-100 text-white dark:text-slate-800 hover:bg-slate-700 dark:hover:bg-slate-300 focus:ring-slate-500 dark:focus:ring-blue-400',
  secondary: 'bg-slate-200 dark:bg-slate-700 text-slate-800 dark:text-slate-200 hover:bg-slate-300 dark:hover:bg-slate-600 focus:ring-slate-400 dark:focus:ring-slate-500',
  outline:
    'bg-transparent border-2 border-slate-800 dark:border-slate-300 text-slate-800 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-700 focus:ring-slate-500 dark:focus:ring-slate-400',
  highlight: 'bg-blue-200 dark:bg-blue-800/60 text-slate-800 dark:text-slate-200 hover:bg-blue-300 dark:hover:bg-blue-700/60 focus:ring-blue-400 dark:focus:ring-blue-500',
};

// Disabled styles
const disabledStyles = 'opacity-60 cursor-not-allowed pointer-events-none';

// Determine the component tag and props based on whether we have an href
const Tag = href ? 'a' : 'button';
const tagProps = href 
  ? { href, disabled: disabled ? true : undefined } 
  : { type, disabled };
---

<Tag
  {...tagProps}
  class:list={[
    baseStyles, 
    sizeStyles[size], 
    variantStyles[variant], 
    disabled && disabledStyles,
    className
  ]}
  aria-label={ariaLabel}
>
  <slot />
</Tag>
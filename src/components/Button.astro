---
import type { ButtonProps } from '../types/props';

type Props = ButtonProps;

const {
  variant = 'primary',
  size = 'md',
  href,
  class: className,
  disabled = false,
  ariaLabel,
  type = 'button', // Default value for type
  id,
} = Astro.props;

// Base styles for all buttons
const baseStyles =
  'inline-block font-medium transition-all duration-200 text-center focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-surface';

// Size variations
const sizeStyles = {
  sm: 'px-3 py-1 text-sm rounded-md',
  md: 'px-4 py-2 rounded-lg',
  lg: 'px-5 py-2.5 text-lg rounded-xl',
};

// Variant styles with semantic colors
const variantStyles = {
  primary: 'bg-content-strong dark:bg-white text-white dark:text-slate-900 hover:bg-theme-700 dark:hover:bg-theme-50 focus:ring-theme-500 dark:focus:ring-accent-400',
  secondary: 'bg-surface-subtle dark:bg-surface-emphasis text-content-strong dark:text-content hover:bg-surface-emphasis dark:hover:bg-surface focus:ring-theme-400 dark:focus:ring-accent-500',
  outline:
    'bg-transparent border-2 border-content-strong dark:border-content text-content-strong dark:text-content hover:bg-surface-subtle dark:hover:bg-surface-emphasis focus:ring-theme-500 dark:focus:ring-accent-400',
  highlight: 'bg-theme-200 dark:bg-theme-800/60 text-content-strong dark:text-content hover:bg-theme-300 dark:hover:bg-theme-700/60 focus:ring-theme-400 dark:focus:ring-accent-500',
};

// Disabled styles
const disabledStyles = 'opacity-60 cursor-not-allowed pointer-events-none';

// Determine the component tag and props based on whether we have an href
const Tag = href ? 'a' : 'button';
const tagProps = href 
  ? { href, disabled: disabled ? true : undefined } 
  : { type, disabled };
---

<Tag
  {...tagProps}
  class:list={[
    baseStyles, 
    sizeStyles[size], 
    variantStyles[variant], 
    disabled && disabledStyles,
    className
  ]}
  aria-label={ariaLabel}
  id={id}
>
  <slot />
</Tag>
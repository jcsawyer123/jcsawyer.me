---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'projects'>['data'];
	class?: string;
}

const { project, class: className = '' } = Astro.props;
---

<div class={`project-card relative ${className}`}>
  <div class="border border-border shadow-default backdrop-blur-md bg-surface-muted rounded-lg h-full relative overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:shadow-medium">
    {project.featured && (
      <div class="absolute top-0 right-0 z-10">
        <div class="w-12 h-12 bg-theme-300 dark:bg-theme-500 rotate-45 transform origin-bottom-right"></div>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-4 h-4 absolute top-1 right-1">
          <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"></path>
        </svg>
      </div>
    )}

    <div class="px-4 py-3 pb-4 flex flex-col h-full">
      <h3 class="text-content-strong font-bold project-title transition-colors duration-200">
        {project.name}
      </h3>
      
      <div class="description-container">
        <p class="text-sm text-content mt-1 description line-clamp-2">
          {project.description}
        </p>
      </div>
      
      <div class="flex-grow"></div>
      
      <div class="flex justify-between items-center mt-2">
        <!-- Expand indicator - only shows on clippable cards -->
        <div class="expand-indicator-container hidden">
          <div class="flex items-center text-xs text-theme-600/70 dark:text-accent-400/70">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 expand-arrow transition-transform duration-200">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
            </svg>
            <span class="expand-text ml-1 w-0 overflow-hidden whitespace-nowrap transition-all duration-200">Click to expand</span>
            <span class="collapse-text ml-1 w-0 overflow-hidden whitespace-nowrap transition-all duration-200 hidden">Click to collapse</span>
          </div>
        </div>
        
        <!-- Link arrow - only visible on hover -->
        <div class="ml-auto">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="link-arrow w-4 h-4 text-theme-600 dark:text-accent-400 opacity-0 transition-opacity duration-200">
            <path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd"></path>
          </svg>
        </div>
      </div>
    </div>
    
    <!-- Interactive overlay -->
    <div class="absolute inset-0 z-20 flex">
      <!-- Left half - for read more -->
      <div class="w-1/2 h-full read-more-area clippable-area hidden cursor-pointer"></div>
      
      <!-- Right half - for link -->
      <a href={project.link} target="_blank" rel="noopener noreferrer" class="w-1/2 h-full ml-auto visit-link-area">
        <span class="sr-only">Visit project: {project.name}</span>
      </a>
      
      <!-- Full card link - used when card isn't clipped -->
      <a href={project.link} target="_blank" rel="noopener noreferrer" class="w-full h-full non-clippable-area">
        <span class="sr-only">Visit project: {project.name}</span>
      </a>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const projectCards = document.querySelectorAll('.project-card');
    
    projectCards.forEach(card => {
      const description = card.querySelector('.description');
      const readMoreArea = card.querySelector('.read-more-area');
      const nonClippableArea = card.querySelector('.non-clippable-area');
      const expandText = card.querySelector('.expand-text');
      const collapseText = card.querySelector('.collapse-text');
      const expandIndicatorContainer = card.querySelector('.expand-indicator-container');
      const expandArrow = card.querySelector('.expand-arrow');
      const linkArrow = card.querySelector('.link-arrow');
      const projectTitle = card.querySelector('.project-title');
      
      // Add hover effects for the entire card
      card.addEventListener('mouseenter', () => {
        projectTitle.classList.add('text-theme-600', 'dark:text-accent-400');
      });
      
      card.addEventListener('mouseleave', () => {
        projectTitle.classList.remove('text-theme-600', 'dark:text-accent-400');
      });
      
      // Check if the description is actually clipped
      setTimeout(() => {
        const isClipped = description.scrollHeight > description.clientHeight;
        
        if (isClipped) {
          // Configure for expandable card
          readMoreArea.classList.remove('hidden');
          nonClippableArea.classList.add('hidden');
          expandIndicatorContainer.classList.remove('hidden');
          card.classList.add('has-read-more');
          
          // Toggle expand/collapse
          readMoreArea.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            
            const isExpanded = !description.classList.contains('line-clamp-2');
            description.classList.toggle('line-clamp-2');
            expandArrow.classList.toggle('rotate-180');
            expandText.classList.toggle('hidden', isExpanded);
            collapseText.classList.toggle('hidden', !isExpanded);
            
            if (isExpanded) {
              expandText.classList.remove('hidden');
              collapseText.classList.add('hidden');
            } else {
              expandText.classList.add('hidden');
              collapseText.classList.remove('hidden');
            }
          });
          
          // Show expanded text on hover over left side
          readMoreArea.addEventListener('mouseenter', () => {
            if (description.classList.contains('line-clamp-2')) {
              expandText.classList.add('w-24');
            } else {
              collapseText.classList.add('w-28');
            }
          });
          
          readMoreArea.addEventListener('mouseleave', () => {
            expandText.classList.remove('w-24');
            collapseText.classList.remove('w-28');
          });
          
          // Handle hover for the right side - only show arrow on right half for clippable cards
          const visitLinkArea = card.querySelector('.visit-link-area');
          visitLinkArea.addEventListener('mouseenter', () => {
            linkArrow.classList.add('opacity-100');
          });
          
          visitLinkArea.addEventListener('mouseleave', () => {
            linkArrow.classList.remove('opacity-100');
          });
        } else {
          // For non-clippable cards, show the arrow on hover anywhere
          nonClippableArea.addEventListener('mouseenter', () => {
            linkArrow.classList.add('opacity-100');
          });
          
          nonClippableArea.addEventListener('mouseleave', () => {
            linkArrow.classList.remove('opacity-100');
          });
        }
      }, 100);
    });
  });
</script>

<style>
  .description-container {
    transition: height 0.3s ease;
  }
  
  .description {
    transition: max-height 0.3s ease;
  }
  
  /* Visual indication for the split card */
  .has-read-more .read-more-area {
    background: linear-gradient(to right, rgba(var(--theme-300-rgb), 0.05), transparent);
  }
  
  .has-read-more:hover .read-more-area {
    background: linear-gradient(to right, rgba(var(--theme-300-rgb), 0.1), transparent);
  }
  
  /* Add a subtle separator between the two halves */
  .has-read-more::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: linear-gradient(to bottom, transparent 10%, rgba(var(--border-rgb), 0.2) 50%, transparent 90%);
    z-index: 5;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  
  .has-read-more:hover::after {
    opacity: 1;
  }
  
  /* Transitions */
  .link-arrow,
  .project-title {
    transition: opacity 0.2s ease, color 0.2s ease;
  }
</style>
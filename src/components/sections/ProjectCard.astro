---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>['data'];
  class?: string;
}

const { project, class: className = '' } = Astro.props;
const hasLink = Boolean(project.link);
const linkLabel = project.linkLabel ?? 'Open';
---

<div class={`project-card group relative ${className}`}>
  <div class="border border-border bg-surface/85 shadow-subtle dark:shadow-none rounded-lg h-full relative overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:shadow-default dark:hover:shadow-none hover:border-theme-300 dark:hover:border-theme-700">
    {project.featured && (
      <div class="absolute top-0 right-0 z-10">
        <div class="w-12 h-12 bg-theme-300 dark:bg-theme-600 rotate-45 transform origin-bottom-right"></div>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-4 h-4 absolute top-1 right-1">
          <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"></path>
        </svg>
      </div>
    )}

    <div class="px-4 py-3 pb-4 flex flex-col h-full">
      {project.context && (
        <div class="text-[11px] font-semibold uppercase tracking-[0.16em] text-theme-600 dark:text-theme-400 mb-2">
          {project.context}
        </div>
      )}

      <h3 class="text-content-strong font-bold transition-colors duration-200 group-hover:text-theme-700 dark:group-hover:text-theme-300">
        {project.name}
      </h3>

      <div class="description-container">
        <p class="text-sm text-content mt-1 description line-clamp-2">
          {project.description}
        </p>
      </div>

      <div class="flex-grow"></div>

      <div class="flex items-center justify-between gap-3 mt-3">
        <button type="button" class="expand-toggle hidden inline-flex items-center gap-1 text-[11px] font-medium uppercase tracking-[0.14em] text-theme-600 dark:text-theme-400">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 expand-arrow transition-transform duration-200">
            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
          </svg>
          <span class="expand-toggle-open">Read more</span>
          <span class="expand-toggle-close hidden">Collapse</span>
        </button>

        {hasLink && (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-auto inline-flex items-center gap-1 text-xs font-medium text-theme-600 dark:text-theme-400"
          >
            <span>{linkLabel}</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd"></path>
            </svg>
            <span class="sr-only">Open work item: {project.name}</span>
          </a>
        )}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.project-card').forEach(card => {
      const description = card.querySelector('.description');
      const expandToggle = card.querySelector('.expand-toggle');
      const expandToggleOpen = card.querySelector('.expand-toggle-open');
      const expandToggleClose = card.querySelector('.expand-toggle-close');
      const expandArrow = card.querySelector('.expand-arrow');

      setTimeout(() => {
        if (!description || !expandToggle || description.scrollHeight <= description.clientHeight) {
          return;
        }

        expandToggle.classList.remove('hidden');

        expandToggle.addEventListener('click', () => {
          const isExpanded = !description.classList.contains('line-clamp-2');
          description.classList.toggle('line-clamp-2', isExpanded);
          expandArrow.classList.toggle('rotate-180', !isExpanded);
          expandToggleOpen.classList.toggle('hidden', !isExpanded);
          expandToggleClose.classList.toggle('hidden', isExpanded);
        });
      }, 100);
    });
  });
</script>

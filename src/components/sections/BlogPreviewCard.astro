---
import Tag from '../Tag.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const postUrl = `/blog/${post.slug}`;
---

<a href={postUrl} class="block group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-theme-400 dark:focus-visible:ring-theme-400">
	<div
		class="border border-border bg-surface/85 shadow-subtle dark:shadow-none relative overflow-hidden rounded-lg h-full flex flex-col transition-all duration-200 pr-4 lg:pr-2 group-hover:-translate-y-0.5 group-hover:shadow-default dark:group-hover:shadow-none group-hover:border-theme-300 dark:group-hover:border-theme-700"
	>
		{post.data.featured && (
			<div class="absolute top-0 right-0 z-10">
				<div class="w-8 h-8 bg-theme-300 dark:bg-theme-600 rotate-45 transform origin-bottom-right"></div>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-3 h-3 absolute top-0.5 right-0.5">
					<path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"></path>
				</svg>
			</div>
		)}

		<div class="px-4 py-3 flex-grow">
			<div class="flex justify-between items-start gap-2">
				<h3 class="text-base font-bold text-content-strong group-hover:text-theme-700 dark:group-hover:text-theme-300 transition-colors duration-200">
					{post.data.title}
				</h3>
				<div class="text-sm text-content-muted ml-2 flex-shrink-0 pt-0.5">
					{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
				</div>
			</div>

			<p class="text-sm text-content mt-1 mb-2 line-clamp-2">
				{post.data.description}
			</p>

			{post.data.tags && post.data.tags.length > 0 && (
				<div class="flex flex-wrap gap-1.5 mt-2">
					{post.data.tags.map((tag) => (
						<Tag label={tag.label} color={tag.color} />
					))}
				</div>
			)}

			<!-- Arrow icon that shows only on hover -->
			<div class="absolute bottom-2 right-3 opacity-0 group-hover:opacity-100 transition-opacity">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-theme-600 dark:text-theme-400">
					<path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd"></path>
				</svg>
			</div>
		</div>
	</div>
</a>

---
import SectionHeader from './SectionHeader.astro';
import Container from '../Container.astro';
import GradientAccent from '../GradientAccent.astro';

const experiences = [
  {
    role: "Software Engineer",
    company: "Fortra · Alert Logic",
    period: "Mar 2022 – Present",
    bullets: [
      "Deployment Configuration Services; backend systems primarily in Erlang",
      "Led MDR integration into AWS Control Tower and owned its continued development",
      "Drove modernisation of the internal erlcloud fork for deployment tooling",
      "Led the Developer Advocacy Initiative",
    ],
  },
  {
    role: "Junior Software Engineer",
    company: "Oxbury Bank",
    period: "Aug 2021 – Mar 2022",
    bullets: [
      "NestJS microservice environment integrated with a PHP core banking platform",
      "AWS deployment and maintenance of microservice architecture",
    ],
  },
  {
    role: "Freelance Web Developer",
    company: "Self-Employed",
    period: "2017 – 2020",
    bullets: [
      "UI/UX mockups and front-end development",
      "Performance optimisation for client codebases",
    ],
  },
  {
    role: "Front-End Web Developer",
    company: "Terrabase",
    period: "2017 – 2018",
    bullets: [],
  },
];
---

<section class="w-full mb-16">
  <div class="max-w-4xl mx-auto px-4 w-full">
    <SectionHeader title="Experience" accent="top" accentSize="md" />
    <div class="max-w-3xl mx-auto">
      <Container frosted panel borderColor="border-border" class="relative overflow-hidden p-6 sm:p-8">
        <GradientAccent position="left" size="lg" />
        <div class="space-y-8 pl-2">
          {experiences.map((exp) => (
            <div class="relative pl-6 border-l border-border-subtle dark:border-border">
              <div class="absolute -left-[5px] top-[7px] w-2.5 h-2.5 rounded-full bg-theme-400 dark:bg-accent-400 ring-2 ring-surface-muted" />
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-0.5 sm:gap-3 mb-2">
                <span class="text-content-strong font-semibold">{exp.role}</span>
                <span class="hidden sm:inline text-border-subtle">·</span>
                <span class="text-content">{exp.company}</span>
                <span class="text-content-subtle text-sm sm:ml-auto whitespace-nowrap">{exp.period}</span>
              </div>
              {exp.bullets.length > 0 && (
                <ul class="space-y-1.5">
                  {exp.bullets.map((bullet) => (
                    <li class="text-content-muted text-sm flex gap-2">
                      <span class="text-theme-400 dark:text-accent-400 mt-0.5 shrink-0 select-none">–</span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </Container>
    </div>
  </div>
</section>

---
import SectionHeader from './SectionHeader.astro';
import Container from '../Container.astro';

const skillGroups = [
  {
    label: "Languages",
    skills: ["JavaScript", "TypeScript", "Erlang", "Java", "C#", "Python"],
    lightClass: "bg-blue-100 text-blue-800",
    darkClass: "dark:bg-blue-900/30 dark:text-blue-300",
  },
  {
    label: "Technologies",
    skills: ["AWS", "Docker", "Git", "MongoDB", "Redis", "DataDog", "Jenkins", "CI/CD"],
    lightClass: "bg-indigo-100 text-indigo-800",
    darkClass: "dark:bg-indigo-900/30 dark:text-indigo-300",
  },
  {
    label: "Frameworks & Libraries",
    skills: ["React", "Next.js", "Gatsby", "Tailwind CSS", "FastAPI", "NestJS", "Flask", "Rails"],
    lightClass: "bg-purple-100 text-purple-800",
    darkClass: "dark:bg-purple-900/30 dark:text-purple-300",
  },
];
---

<section class="w-full mb-16">
  <div class="max-w-4xl mx-auto px-4 w-full">
    <SectionHeader title="Skills" accent="top" accentSize="md" />
    <div class="max-w-3xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-4">
      {skillGroups.map((group) => (
        <Container frosted panel borderColor="border-border" class="p-5">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-content-subtle mb-3">
            {group.label}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class:list={[
                "inline-block px-2 py-0.5 rounded-full text-xs font-medium",
                group.lightClass,
                group.darkClass,
              ]}>
                {skill}
              </span>
            ))}
          </div>
        </Container>
      ))}
    </div>
  </div>
</section>

---
const skillGroups = [
  {
    label: "Languages",
    skills: ["JavaScript", "TypeScript", "Erlang", "Java", "C#", "Python"],
  },
  {
    label: "Technologies",
    skills: ["AWS", "Docker", "Git", "MongoDB", "Redis", "DataDog", "Jenkins", "CI/CD"],
  },
  {
    label: "Frameworks",
    skills: ["React", "Next.js", "Gatsby", "Tailwind CSS", "FastAPI", "NestJS", "Flask", "Rails"],
  },
];
---

<section class="w-full mb-16">
  <div class="max-w-4xl mx-auto px-4 w-full">
    <div class="max-w-3xl mx-auto pt-12">

      <div class="flex items-center gap-4 mb-10">
        <span class="text-xs font-mono text-theme-500 dark:text-theme-400 tracking-widest shrink-0">02</span>
        <h2 class="text-2xl font-bold text-content-strong shrink-0">Skills</h2>
        <div class="flex-1 h-px bg-border-subtle"></div>
      </div>

      <div class="space-y-5">
        {skillGroups.map((group) => (
          <div class="flex flex-col sm:flex-row sm:gap-10">
            <div class="w-full sm:w-[180px] shrink-0 mb-2 sm:mb-0 sm:pt-1">
              <span class="text-sm text-content-subtle">{group.label}</span>
            </div>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class="inline-block px-2.5 py-1 rounded-md text-xs font-medium bg-theme-100 text-theme-800 dark:bg-surface-emphasis dark:text-content dark:border dark:border-border">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

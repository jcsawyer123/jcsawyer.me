---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const postUrl = `/blog/${post.slug}`;
const displayDate = post.data.pubDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
});
---

<a
  href={postUrl}
  class="block group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-theme-400 dark:focus-visible:ring-theme-400 rounded-xl transition-all duration-200"
>
  <div class="border border-border shadow-subtle dark:shadow-none bg-surface/85 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-default dark:hover:shadow-none hover:border-theme-300 dark:hover:border-theme-700 rounded-xl px-5 py-4 sm:px-6 sm:py-5 relative">
    {/* Top row: Date and Featured */}
    <div class="flex items-center justify-between mb-1">
      <span class="text-sm text-content-muted">
        {displayDate}
      </span>
      {post.data.featured && (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-5 h-5 text-theme-600 dark:text-theme-400"
          aria-label="Featured"
        >
          <path
            fill-rule="evenodd"
            d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z"
            clip-rule="evenodd"
          ></path>
        </svg>
      )}
    </div>

    {/* Title */}
    <h3 class="text-lg sm:text-xl font-bold text-content-strong mb-1 group-hover:text-theme-700 dark:group-hover:text-theme-300 transition-colors duration-200">
      {post.data.title}
    </h3>

    {/* Description */}
    <p class="text-sm text-content mb-2 line-clamp-1">
      {post.data.description}
    </p>

    {/* Arrow icon that shows only on hover */}
    <div class="absolute bottom-3.5 right-4 opacity-0 group-hover:opacity-100 transition-all duration-200 pointer-events-none">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="w-4 h-4 text-theme-600 dark:text-theme-400"
      >
        <path
          fill-rule="evenodd"
          d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z"
          clip-rule="evenodd"
        ></path>
      </svg>
    </div>
  </div>
</a>

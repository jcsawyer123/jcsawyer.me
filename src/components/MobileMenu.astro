---
import { isEnabled } from '../config/flags';
import { isActive } from '../utils/nav';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const showBlogPage = isEnabled('showBlogPage');
const showContactPage = isEnabled('showContactPage');
---

<div class="md:hidden">
  <button
    id="mobile-menu-button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
    class="p-1.5 rounded-lg text-content hover:bg-surface-subtle dark:hover:bg-surface-emphasis focus:outline-none focus:ring-2 focus:ring-theme-400 dark:focus:ring-theme-400 transition-colors duration-200"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
    </svg>
  </button>

  <div
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
    class="hidden fixed inset-0 z-[60] bg-surface/95 backdrop-blur-lg"
  >
    <div class="flex items-center justify-between px-5 py-4">
      <a href="/" class="font-bold text-xl text-content-strong">J. Sawyer</a>
      <button
        id="mobile-menu-close"
        aria-label="Close navigation menu"
        class="p-1.5 rounded-lg text-content hover:bg-surface-subtle dark:hover:bg-surface-emphasis focus:outline-none focus:ring-2 focus:ring-theme-400 dark:focus:ring-theme-400 transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="flex flex-col items-center justify-center gap-8 h-[calc(100%-61px)]">
      <a
        href="/"
        class:list={[
          'text-2xl font-semibold transition-colors duration-200',
          isActive(currentPath, '/')
            ? 'text-theme-600 dark:text-theme-400'
            : 'text-content-strong hover:text-theme-600 dark:hover:text-theme-400',
        ]}
      >Home</a>
      {showBlogPage && (
        <a
          href="/blog"
          class:list={[
            'text-2xl font-semibold transition-colors duration-200',
            isActive(currentPath, '/blog')
              ? 'text-theme-600 dark:text-theme-400'
              : 'text-content-strong hover:text-theme-600 dark:hover:text-theme-400',
          ]}
        >Blog</a>
      )}
      {showContactPage && (
        <a
          href="/contact"
          class:list={[
            'text-2xl font-semibold transition-colors duration-200',
            isActive(currentPath, '/contact')
              ? 'text-theme-600 dark:text-theme-400'
              : 'text-content-strong hover:text-theme-600 dark:hover:text-theme-400',
          ]}
        >Contact</a>
      )}
    </nav>
  </div>
</div>

<style>
  #mobile-menu:not(.hidden) {
    display: flex;
    flex-direction: column;
  }
</style>

<script>
  const initMobileMenu = () => {
    const menuButton = document.getElementById('mobile-menu-button');
    const closeButton = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!menuButton || !closeButton || !mobileMenu) return;

    // The navbar has backdrop-blur which creates a stacking context in Chrome,
    // trapping fixed children inside it. Moving to body escapes that.
    if (mobileMenu.parentElement !== document.body) {
      document.body.appendChild(mobileMenu);
    }

    const navbar = document.getElementById('main-navbar');

    const open = () => {
      mobileMenu.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
      menuButton.setAttribute('aria-expanded', 'true');
      navbar?.classList.add('border-transparent');
    };

    const close = () => {
      mobileMenu.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
      menuButton.setAttribute('aria-expanded', 'false');
      navbar?.classList.remove('border-transparent');
    };

    menuButton.addEventListener('click', open);
    closeButton.addEventListener('click', close);

    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', close);
    });

    document.addEventListener('astro:before-swap', close);
  };

  document.addEventListener('DOMContentLoaded', initMobileMenu);
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>

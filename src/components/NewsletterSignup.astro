---
import Button from './Button.astro';

const { className = '' } = Astro.props;
---
<div class:list={[
  'border border-border shadow-default rounded-xl p-1 md:p-2',
  className
]}>
  <div class="p-panel-sm">
    <h3 class="text-xl sm:text-2xl font-bold text-content-strong mb-2">Stay updated</h3>
    <p class="text-sm text-content mb-3">
      Get notified when new articles are published
    </p>
    <form class="space-y-2">
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        id="newsletter-email"
        type="email"
        placeholder="Your email"
        class="w-full px-3 py-2 border-2 border-border rounded-md bg-surface-muted/50 dark:bg-surface-emphasis/50 text-content placeholder-content-subtle focus:outline-none focus:ring-2 focus:ring-theme-400 dark:focus:ring-accent-400"
        required
      />
      <Button type="submit" variant="primary" class="w-full">Subscribe</Button>
    </form>
  </div>
</div>